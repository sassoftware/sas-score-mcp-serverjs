PORT=8080
# set this to false if you want this to run azure
HTTPS=FALSE
MCPTYPE=http
AUTHFLOW=sascli
APPHOST=0.0.0.0
SAS_CLI_PROFILE=dtl
CAS_SERVER=cas-shared-default
# APPNAME defaults to sas-score-mcp-serverjs but you can override it here
APPNAME=sas-score-mcp-serverjs
COMPUTECONTEXT=SAS Job Execution compute context
SAMESITE=Lax,secure
# REDIRECT=/info
VIYACERT=./.viyatls
SSLCERT=./.viyatls
USEHAPI=TRUE
